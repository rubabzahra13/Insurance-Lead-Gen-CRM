# Copy to .env and fill in secrets:
#   cp .env.example .env

ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=
LLM_PROVIDER=claude
MAX_RESULTS=25
MIN_CONFIDENCE=0.55
NODE_ENV=development
PORT=3001
SUPABASE_CONNECTION_STRING=
PLACES_API_KEY=
PUBLIC_APP_URL=http://localhost:3000

# Outreach — email (SMTP). Without these, messages are logged to backend/logs/outreach.log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Outreach — SMS (Twilio). Optional; falls back to outreach.log when unset
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Landing page YouTube embed (optional; frontend default is insurance career overview)
NEXT_PUBLIC_LANDING_VIDEO_YOUTUBE_ID=wRpsFyb_lp4

