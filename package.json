{
  "name": "linkedin-leads",
  "version": "1.0.0",
  "description": "Find public LinkedIn profiles via Gemini Google Search grounding",
  "type": "module",
  "bin": {
    "linkedin-leads": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "scrape": "node src/index.js",
    "server": "node src/server.js",
    "dev:web": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "dev": "concurrently -n api,web -c cyan,magenta \"node src/server.js\" \"vite\"",
    "start:app": "node src/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "googleapis": "^148.0.0",
    "postgres": "^3.4.7",
    "react": "^19.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.17.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.8",
    "vite": "^6.3.5"
  }
}
