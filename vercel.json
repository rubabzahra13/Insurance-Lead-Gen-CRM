{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "framework": "fastapi",
      "entrypoint": "index:app",
      "functions": {
        "index.py": {
          "maxDuration": 60,
          "includeFiles": "app/**"
        }
      }
    },
    "scraper": {
      "root": "backend",
      "entrypoint": "scraper.js",
      "functions": {
        "scraper.js": {
          "maxDuration": 300
        }
      }
    }
  },
  "rewrites": [
    { "source": "/api/scrape", "destination": { "service": "scraper" } },
    { "source": "/api/scrape/(.*)", "destination": { "service": "scraper" } },
    { "source": "/api/(.*)", "destination": { "service": "backend" } },
    { "source": "/(.*)", "destination": { "service": "frontend" } }
  ]
}
